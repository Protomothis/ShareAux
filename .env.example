# ShareAux Environment Variables / 환경 변수 설정
# Copy this file to .env and edit the values.
# 이 파일을 .env로 복사한 뒤 값을 수정하세요.
# Must be in the same directory as docker-compose.yml.
# docker-compose.yml과 같은 디렉토리에 위치해야 합니다.

# ===== Required / 필수 =====

# DB password (auto-used by docker-compose) / DB 비밀번호
DB_PASSWORD=change-me

# JWT secret (must change to random string) / JWT 시크릿 (랜덤 문자열로 변경 필수)
JWT_SECRET=change-me-to-random-secret

# Client URL (use actual domain with reverse proxy) / 클라이언트 URL (리버스 프록시 시 실제 도메인)
CLIENT_URL=http://localhost:3001

# ===== Optional / 선택 =====

# Google OAuth (Google login disabled if unset / 미설정 시 Google 로그인 비활성)
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# CAPTCHA (default: enabled / 기본: 활성)
#CAPTCHA_ENABLED=true

# Gemini API (lyrics translation, disabled if unset / 가사 번역, 미설정 시 비활성)
#GEMINI_API_KEY=

# JWT expiration / JWT 만료 시간
#JWT_EXPIRES_IN=1h
#JWT_REFRESH_EXPIRES_IN=7d

# Max rooms / 최대 방 수
#MAX_ROOMS=20

# Rate Limiting / 속도 제한
#THROTTLE_TTL=60
#THROTTLE_LIMIT=60
