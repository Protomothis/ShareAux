# ShareAux 환경 변수 설정
# 이 파일을 .env로 복사한 뒤 값을 수정하세요.
# docker-compose.yml과 같은 디렉토리에 위치해야 합니다.

# ===== 필수 =====

# DB 비밀번호 (docker-compose에서 자동 사용)
DB_PASSWORD=change-me

# JWT 시크릿 (랜덤 문자열로 변경 필수)
JWT_SECRET=change-me-to-random-secret

# 클라이언트 URL (리버스 프록시 사용 시 실제 도메인)
CLIENT_URL=http://localhost:3001

# ===== 선택 =====

# Google OAuth (미설정 시 Google 로그인 비활성)
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# CAPTCHA (기본: 활성)
#CAPTCHA_ENABLED=true

# Gemini API (가사 번역, 미설정 시 번역 비활성)
#GEMINI_API_KEY=

# JWT 만료 시간
#JWT_EXPIRES_IN=1h
#JWT_REFRESH_EXPIRES_IN=7d

# 최대 방 수
#MAX_ROOMS=20

# Rate Limiting
#THROTTLE_TTL=60
#THROTTLE_LIMIT=60
